{
  "name": "assetflow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace=client --",
    "build": "npm run build --workspace=client --",
    "preview": "npm run preview --workspace=client --",
    "server": "npm run dev --workspace=server --",
    "check:server": "npm run check --workspace=server",
    "test:server": "npm test --workspace=server",
    "seed:admin": "npm run seed:admin --workspace=server",
    "seed:organization": "npm run seed:organization --workspace=server"
  }
}
